<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CardGamesApp.ViewModels"
             x:Class="CardGamesApp.Views.OczkoView"
             x:DataType="vm:OczkoViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="20">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Gra 2: Oczko"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Dobieraj karty tak, aby mieć jak najbliżej 21. Możesz też usunąć jedną wybraną kartę."
                       Foreground="#CDD6F4"
                       FontSize="15"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="#313244"
                CornerRadius="16"
                Padding="28"
                Width="760"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                <StackPanel Grid.Column="0" Spacing="14">
                    <TextBlock Text="Twoje karty:"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White" />

                    <ListBox ItemsSource="{Binding KartyGracza}"
                             SelectedItem="{Binding WybranaKartaGracza}"
                             Height="160"
                             FontSize="18" />

                    <TextBlock Text="{Binding SumaGraczaTekst}"
                               FontSize="18"
                               Foreground="#A6E3A1" />

                    <Button Content="Usuń wybraną kartę"
                            Command="{Binding UsunWybranaKarteCommand}"
                            Height="45" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="14">
                    <TextBlock Text="Karty krupiera:"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White" />

                    <TextBlock Text="{Binding KartyKrupieraTekst}"
                               FontSize="18"
                               Foreground="#CDD6F4"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding SumaKrupieraTekst}"
                               FontSize="18"
                               Foreground="#A6E3A1" />

                    <TextBlock Text="{Binding Komunikat}"
                               FontSize="18"
                               Foreground="#F9E2AF"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12">
            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    Width="120"
                    Height="45" />

            <Button Content="Dobierz"
                    Command="{Binding DobierzCommand}"
                    Width="120"
                    Height="45" />

            <Button Content="Zostań"
                    Command="{Binding ZostanCommand}"
                    Width="120"
                    Height="45" />

            <Button Content="Powrót do menu"
                    Command="{Binding PowrotDoMenuCommand}"
                    Width="180"
                    Height="45" />
        </StackPanel>
    </Grid>
</UserControl>