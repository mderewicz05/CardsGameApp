<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CardGamesApp.ViewModels"
             x:Class="CardGamesApp.Views.MainMenuView"
             x:DataType="vm:MainMenuViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="Gry karciane"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Projekt laboratoryjny - Avalonia UI"
                       FontSize="16"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding PlayerCount, StringFormat='Liczba dodanych graczy: {0}'}"
                       FontSize="14"
                       Foreground="#A6ADC8"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              RowDefinitions="Auto,Auto,Auto"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="650"
              RowSpacing="16"
              ColumnSpacing="16">

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Content="Dodaj graczy"
                    Command="{Binding GoToPlayersCommand}"
                    Height="70"
                    FontSize="18" />

            <Button Grid.Row="0"
                    Grid.Column="1"
                    Content="Historia rozgrywek"
                    Command="{Binding GoToHistoryCommand}"
                    Height="70"
                    FontSize="18" />

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Content="Gra 1: Wojna"
                    Command="{Binding GoToWarGameCommand}"
                    Height="70"
                    FontSize="18" />

            <Button Grid.Row="1"
                    Grid.Column="1"
                    Content="Gra 2: Oczko / 21"
                    Command="{Binding GoToTwentyOneGameCommand}"
                    Height="70"
                    FontSize="18" />

            <Button Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Content="Gra 3: Higher or Lower"
                    Command="{Binding GoToHigherLowerGameCommand}"
                    Height="70"
                    FontSize="18" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Najpierw dodaj graczy, potem wybierz jedną z gier."
                   Foreground="#A6ADC8"
                   HorizontalAlignment="Center"
                   FontSize="14" />
    </Grid>
</UserControl>