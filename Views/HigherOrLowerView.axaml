<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CardGamesApp.ViewModels"
             x:Class="CardGamesApp.Views.HigherOrLowerView"
             x:DataType="vm:HigherOrLowerViewModel">

	<Grid RowDefinitions="*, Auto">

		<StackPanel Grid.Row="0" Margin="20" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Top">

			<TextBlock Text="Higher or Lower" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

			<Border BorderBrush="Black" BorderThickness="2" CornerRadius="10" Padding="20" Background="White" Width="160">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="{Binding CurrentCard.Figura}" FontSize="40" HorizontalAlignment="Center" Foreground="Black"/>
					<TextBlock Text="{Binding CurrentCard.Kolor}" FontSize="60" HorizontalAlignment="Center" Foreground="Black"/>
				</StackPanel>
			</Border>

			<TextBlock Text="{Binding Message}" TextWrapping="Wrap" TextAlignment="Center" FontSize="16" MaxWidth="400"/>
			<TextBlock Text="{Binding Score, StringFormat='Twoj wynik: {0}'}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>

			<StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
				<Button Content="NIZSZA" Command="{Binding GuessLowerCommand}"
                        Width="120" Height="50" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="Firebrick" Foreground="White"/>

				<Button Content="WYZSZA" Command="{Binding GuessHigherCommand}"
                        Width="120" Height="50" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="ForestGreen" Foreground="White"/>
			</StackPanel>

			<StackPanel Spacing="10" Margin="0,10,0,0" IsVisible="{Binding ShowSuitGuess}">
				<TextBlock Text="Zgadnij kolor karty dla bonusu:" HorizontalAlignment="Center" FontWeight="Bold"/>
				<UniformGrid Columns="2" Width="260">
					<Button Content="Kier ♥" Command="{Binding GuessSuitCommand}" CommandParameter="Kier" Margin="2" HorizontalContentAlignment="Center"/>
					<Button Content="Karo ♦" Command="{Binding GuessSuitCommand}" CommandParameter="Karo" Margin="2" HorizontalContentAlignment="Center"/>
					<Button Content="Pik ♠️" Command="{Binding GuessSuitCommand}" CommandParameter="Pik" Margin="2" HorizontalContentAlignment="Center"/>
					<Button Content="Trefl ♣" Command="{Binding GuessSuitCommand}" CommandParameter="Trefl" Margin="2" HorizontalContentAlignment="Center"/>
				</UniformGrid>
			</StackPanel>

		</StackPanel>

		<Button Grid.Row="1" Content="Powrót do menu"
                Command="{Binding PowrotDoMenuCommand}"
                Width="260" Height="35"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Margin="0,0,0,5"
                HorizontalAlignment="Center"
                Background="#444455"
                Foreground="White"/>

	</Grid>
</UserControl>